{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "bundler",

    "types": ["node", "@playwright/test"],

    "strict": true,
    "skipLibCheck": true,

    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },

  "include": [
    "tests",
    "pages",
    "fixtures",
    "data",
    "playwright.config.ts"
  ]
}
